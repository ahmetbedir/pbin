{
    "name": "ahmetbedir/pbin",
    "description": "Create end-to-end encrypted PrivateBin pastes from your terminal.",
    "keywords": ["privatebin", "cli", "encryption", "paste", "zero-knowledge"],
    "homepage": "https://github.com/ahmetbedir/pbin",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/ahmetbedir/pbin/issues",
        "source": "https://github.com/ahmetbedir/pbin"
    },
    "authors": [
        {
            "name": "Ahmet Bedir"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^12.17",
        "laravel-zero/framework": "^12.0.2",
        "nunomaduro/laravel-console-task": "^1.11"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "phpacker/phpacker": "^0.6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["pbin"]
}
